{
  "openapi": "3.0.0",
  "info": {
    "title": "Loan API",
    "version": "1.0.0",
    "description": "API для управления заявками на кредит"
  },
  "servers": [
    {"url": "/", "description": "API Server"}
  ],
  "paths": {
    "/requests": {
      "post": {
        "summary": "Создать заявку на кредит",
        "tags": ["Заявки"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["user_id", "amount", "term"],
                "properties": {
                  "user_id": {"type": "integer", "example": 1},
                  "amount": {"type": "integer", "example": 10000},
                  "term": {"type": "integer", "example": 12}
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Заявка создана",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {"type": "boolean", "example": true},
                    "id": {"type": "integer", "example": 1}
                  }
                }
              }
            }
          },
          "400": {
            "description": "Ошибка: уже есть одобренная заявка или невалидные данные",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {"type": "boolean", "example": false}
                  }
                }
              }
            }
          }
        }
      }
    },
    "/processor": {
      "get": {
        "summary": "Обработать ожидающие заявки",
        "tags": ["Процессор"],
        "parameters": [
          {
            "name": "delay",
            "in": "query",
            "required": false,
            "description": "Задержка в секундах между обработкой заявок",
            "schema": {"type": "integer", "default": 0}
          }
        ],
        "responses": {
          "200": {
            "description": "Заявки успешно обработаны",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "result": {"type": "boolean", "example": true}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
